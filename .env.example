# =====================================================
# CreatorDeck — Environment Variables
# Copy to .env.local for development. Never commit .env*.
# =====================================================

# ----- Core -----
NODE_ENV=development

# ----- API server -----
PORT=4000
API_URL=http://localhost:4000

# ----- Database (PostgreSQL 16) -----
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://creatordeck:creatordeck@localhost:5432/creatordeck

# Optional read replica
DATABASE_REPLICA_URL=

# ----- Redis (Upstash or local) -----
REDIS_URL=redis://localhost:6379

# ----- Clerk auth -----
# Server-side (api + Next.js server components)
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public (Next.js client-side)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk webhook secret (for syncing users into our DB)
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Stripe (Phase 2 escrow) -----
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Cloudflare R2 (file storage) -----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=creatordeck-media
R2_PUBLIC_URL=https://cdn.creatordeck.com

# ----- Resend (transactional email) -----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@creatordeck.com

# ----- Web app -----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Observability -----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=creatordeck

# ----- Feature flags -----
ENABLE_SEARCH_CACHE=true
ENABLE_RATE_LIMIT=true

# ----- Encryption (for OAuth tokens at rest, Phase 2) -----
# 32-byte hex key for AES-256-GCM
TOKEN_ENCRYPTION_KEY=
